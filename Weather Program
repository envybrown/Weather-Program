//intro definition
    void intro(){
        cout<<"This code will determine wind chill and cloud base.";
        cout<<"\nPlease provide..." << endl;
}

//collection definition
void collection(double& temp,double& windSpeed, double& dewPoint){
    cout<<"\nDegrees (Fahrenheit): ";
    while (!(cin>>temp)){
        error();
        cout<<"Degrees (Fahrenheit): ";
    }
    
    cout<<"Wind Speed (mph): ";
    while (!(cin>>windSpeed)){
        error();
        cout<<"Wind Speed (mph): ";
    }
    
    cout<<"Dew Point: ";
    while (!(cin>>dewPoint)){
        error();
        cout<<"Dew Point: ";
    }
}

//wind chill definition
float calc_windChill(double& temp, double& windSpeed, double& windChill){ 
windChill=35.74+(0.6215*temp)-(35.75*pow(windSpeed, 0.16))+(0.4275*temp*pow(windSpeed, 0.16));
    cout<<windChill;
    return 0;
}

//cloud base definition 
float calc_cloudBase(double& temp, double& dewPoint, double& cloudBase){
cloudBase=1000*((temp-dewPoint)/4.4);
    cout<<cloudBase;
    return 0;
}

//error definition... user may only enter numbers
void error(){
    if (cin.fail()) {
        cin.clear();                
        cin.ignore(1000, '\n');     
        cout << "Error. Please try again.\n";
    }
}
