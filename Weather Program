void error();

//main code... weather calculator 
int main()
{
    double temp, windSpeed, dewPoint, windChill, cloudBase;
    
//introduction
    intro();
    
//ask user for variables and collect them
    collection(temp, windSpeed, dewPoint);
    
//show wind chill
cout<<"\nWind chill:\n";  
